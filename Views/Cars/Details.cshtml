@using WebAppAdvance.ModelsView
@model DetailsViewModel

@{
    ViewData["Title"] = "Car Details";
}

<h2 class="mb-4">Car Details</h2>

<div class="card">
    <div class="card-body">

        <h4 class="card-title">@Model.Brand @Model.Model</h4>
        <hr />

        <dl class="row">
            <dt class="col-sm-3">Brand</dt>
            <dd class="col-sm-9">@Model.Brand</dd>

            <dt class="col-sm-3">Model</dt>
            <dd class="col-sm-9">@Model.Model</dd>

            <dt class="col-sm-3">Year</dt>
            <dd class="col-sm-9">@Model.Year</dd>

            <dt class="col-sm-3">Passengers</dt>
            <dd class="col-sm-9">@Model.Pasengers</dd>

            <dt class="col-sm-3">Price Per Day</dt>
            <dd class="col-sm-9">@Model.PricePerDay.ToString("F2") лв.</dd>
        </dl>

    </div>
</div>

<div class="mt-3">
    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Back</a>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
</div>
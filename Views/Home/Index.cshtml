@using WebAppAdvance.ModelsView
@model IEnumerable<CarsIndexViewModel>

@{
    ViewData["Title"] = "Home Page";
}

<h1 class="text-center mb-4">Available Cars</h1>

@if (!Model.Any())
{
    <p class="text-center">No cars available.</p>
}
else
{
    <div class="row">
        @foreach (var car in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h4 class="card-title">@car.Brand @car.Model</h4>
                        <p class="card-text">
                            <strong>Year:</strong> @car.Year
                        </p>
                        <p class="card-text">
                            <strong>Passengers:</strong> @car.Pasengers
                        </p>
                        <p class="card-text">
                            <strong>Price per day:</strong> @car.PricePerDay.ToString("F2") lv.
                        </p>
                    </div>
                    <div class="card-footer text-center">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <a asp-controller="Cars" asp-action="Details" asp-route-id="@car.Id" class="btn btn-info btn-sm">
                                Details
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">Login to see more details</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
